{
  "name": "obtrack",
  "version": "1.0.0",
  "description": "Trading journal",
  "author": "OBTrack",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-win-arm": "electron-builder --win --arm64",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.obtrack.app",
    "productName": "OBTrack",
    "asar": false,
    "files": [
      "main.js",
      "index.html",
      "icon.ico",
      "icon.icns"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OBTrack"
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
